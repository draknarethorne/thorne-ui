{
  "_comment": "Texture theme overrides for slot styling. Inherits from .Master/.regen_slots.json",

  "default_button": {
    "button_row": 1,
    "button_col": 2,
    "gradient": "texture"
  },
  "default_item": {
    "fit_mode": "visible",
    "fit_size": 30,
    "offset_x": 0,
    "offset_y": 1,
    "item_opacity": 0.90
  },

  "gradient_presets": {
    "texture": {
      "type": "diagonal_tl",
      "top_color": [45, 48, 52],
      "middle_color": [160, 170, 180],
      "bottom_color": [110, 120, 130]
    }
  },

  "item_overrides": {
    "logo_1": { "gradient": "phantom" },
    "logo_2": { "gradient": "ghost" },
    "logo_3": { "gradient": "shadow" },
    "logo_4": { "gradient": "dawn" },
    "logo_5": { "gradient": "dusk" },
    "logo_6": { "gradient": "platinum_gleam" }
  }
}
