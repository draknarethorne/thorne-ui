  <!-- SCRIBE GAUGE - Gold Veil (5-band composite)  EQType 10              -->
  <!-- ====================================================================== -->
  <!-- Veil: Ancient Gold (full) > Gilded Quill > Molten Script > Sunlit Parchment > Aureate Glow (starting) -->
  <!-- Z-order: BG > Aureate Glow(0) > Sunlit Parchment(1) > Molten Script(2) > Gilded Quill(3) > Ancient Gold(4) -->
  <!--                                                                        -->
  <!-- 105px gauge — grid positions (0-based): 0, 21, 42, 62, 82, 104        -->
  <!-- Clip CX = midpoint test (20, 41, 61, 81) — halfway between 5/26/46/66 and 35/56/76/96 -->
  <!--   Band 1: clip 20  Band 2: clip 41  Band 3: clip 61  Band 4: clip 81  -->
  <!--   B-part: X = base + clip, CX = 105 - clip, GaugeOffsetX = -clip      -->

  <!-- Background (empty gauge frame) -->
  <Gauge item="SBW_Scribe_BG">
    <ScreenID>SBW_Scribe_BG</ScreenID>
    <EQType>10</EQType>
    <GaugeOffsetX>0</GaugeOffsetX>
    <GaugeOffsetY>0</GaugeOffsetY>
    <RelativePosition>true</RelativePosition>
    <Location><X>64</X><Y>373</Y></Location>
    <Size><CX>105</CX><CY>16</CY></Size>
    <TextOffsetX>8000</TextOffsetX>
    <TextOffsetY>8000</TextOffsetY>
    <Style_Transparent>false</Style_Transparent>
    <DrawLinesFill>false</DrawLinesFill>
    <GaugeDrawTemplate>
      <Background>A_GaugeBackground_105t</Background>
    </GaugeDrawTemplate>
  </Gauge>

  <!-- Band 0: Aureate Glow (255,230,160) - base, visible at any progress -->
  <Gauge item="SBW_Scribe_Band0">
    <ScreenID>SBW_Scribe_Band0</ScreenID>
    <EQType>10</EQType>
    <GaugeOffsetX>0</GaugeOffsetX>
    <GaugeOffsetY>0</GaugeOffsetY>
    <RelativePosition>true</RelativePosition>
    <Location><X>64</X><Y>373</Y></Location>
    <Size><CX>105</CX><CY>16</CY></Size>
    <TextOffsetX>8000</TextOffsetX>
    <TextOffsetY>8000</TextOffsetY>
    <Style_Transparent>false</Style_Transparent>
    <FillTint><R>255</R><G>230</G><B>160</B></FillTint>
    <DrawLinesFill>false</DrawLinesFill>
    <GaugeDrawTemplate>
      <Fill>A_GaugeLightGridFill_105t</Fill>
    </GaugeDrawTemplate>
  </Gauge>

  <!-- Band 1A: Sunlit Parchment (255,200,100) - 20% threshold -->
  <Gauge item="SBW_Scribe_1A">
    <ScreenID>SBW_Scribe_1A</ScreenID>
    <EQType>10</EQType>
    <GaugeOffsetX>-2000</GaugeOffsetX>
    <GaugeOffsetY>0</GaugeOffsetY>
    <RelativePosition>true</RelativePosition>
    <Location><X>0</X><Y>0</Y></Location>
    <Size><CX>8000</CX><CY>16</CY></Size>
